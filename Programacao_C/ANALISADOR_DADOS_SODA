import pandas as pd
import json
import os
import glob
import platform
from datetime import datetime

# --- CONFIGURAÇÃO DINÂMICA DE CAMINHOS ---
# Se rodar no Windows (Servidor), usa o caminho de rede. Se não, usa o local do Codespaces.
if platform.system() == "Windows":
    BASE_PATH = r"\\acswpj7\nr\Projetos_NR\ITF\Compartilhada\01 - Dados & Projetos\Compartilhada\11 Dados\Base_Soda"
else:
    BASE_PATH = "/workspaces/cadastro-cartas-BritoAilson/Programacao_C"

MAPPING_FILE = os.path.join(BASE_PATH, "ponto_produtivo_mes.xlsx - Plan1.csv")

def extract_point_id(row):
    try:
        req = json.loads(row['request'])
        return req.get('codigoPontoProdutivo')
    except:
        return row['id']

def processar():
    # 1. Busca automática do log mais recente
    arquivos = glob.glob(os.path.join(BASE_PATH, "Log-data-*.csv"))
    if not arquivos:
        print(f"❌ Nenhum log encontrado em {BASE_PATH}")
        return

    mais_recente = max(arquivos, key=os.path.getmtime)
    print(f"📂 Analisando: {os.path.basename(mais_recente)}")

    # 2. Leitura dos dados
    df_logs = pd.read_csv(mais_recente)
    df_map = pd.read_csv(MAPPING_FILE, skiprows=2)

    # 3. Filtragem de Erros (Lógica de Diagnóstico)
    erros = df_logs[
        (df_logs['status_processamento'] != 'OK') | 
        (~df_logs['return'].astype(str).isin(['200', '202']))
    ].copy()

    if erros.empty:
        print("✅ Tudo limpo! Nenhum erro encontrado.")
        return

    # 4. Cruzamento de Dados (Join)
    erros['extracted_point_id'] = erros.apply(extract_point_id, axis=1)
    erros['extracted_point_id'] = pd.to_numeric(erros['extracted_point_id'], errors='coerce')
    df_map['cod_ponto_produtivo'] = pd.to_numeric(df_map['cod_ponto_produtivo'], errors='coerce')

    resultado = erros.merge(df_map, left_on='extracted_point_id', right_on='cod_ponto_produtivo', how='left')

    # 5. Sugestões de Solução (Expert System)
    dicas = {
        'Campos incorretos': 'Erro de Schema: Validar se o Node-RED está enviando Float ou Int corretamente.',
        'Coleta já realizada': 'Deduplicação: O CLP enviou o mesmo trigger duas vezes.',
        'Mensagem não recebida': 'Rede: Verificar oscilação na VLAN Industrial.',
        'Erros de datas/lotes': 'Sincronismo: Validar relógio NTP do Gateway.'
    }
    
    resultado['Sugestão'] = resultado['status_processamento'].map(dicas).fillna('Analisar postback_description.')

    # 6. Exportação automática
    data_hora = datetime.now().strftime("%Y%m%d_%H%M")
    nome_saida = f"RELATORIO_ERROS_SODA_{data_hora}.csv"
    caminho_saida = os.path.join(BASE_PATH, nome_saida)
    
    resultado.to_csv(caminho_saida, index=False, encoding='utf-8-sig')
    print(f"✅ Sucesso! Relatório gerado: {nome_saida}")

if __name__ == "__main__":
    processar()